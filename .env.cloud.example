# NourishAI "Truly Free" Cloud Environment Variables

# --- LLM API Keys (LiteLLM) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database Mode ---
# "supabase" (default when SUPABASE_URL+KEY are set) or "sqlite" (local file, no cloud DB needed)
# Omit or leave blank to use auto-detection.
# DB_MODE=supabase

# --- Supabase Configuration (Database) ---
# Get these from your Supabase Project Settings > API
# Required when DB_MODE=supabase (or when SUPABASE_URL+KEY are both present)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# --- Pinecone Configuration (Vector Store) ---
# Get these from your Pinecone Dashboard
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=recipes

# --- Google OAuth (Calendar Integration) ---
REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# --- Security ---
SESSION_SECRET=a_very_long_random_string_here

# --- Frontend (Vercel) ---
VITE_API_URL=https://your-app.vercel.app
