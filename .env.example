# NourishAI Environment Variables Template

# --- LLM API Keys ---
# Required for LiteLLM (GPT-4o-mini, Gemini, etc.)
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here (if using OpenAI)

# --- Backend Configuration ---
HOST=0.0.0.0
PORT=8000
# DATA_DIR should be a persistent volume path (e.g., /app/data)
DATA_DIR=/app/data

# --- Security ---
# Secret key for session management
SESSION_SECRET=a_very_long_random_string_here

# --- Google OAuth ---
# The redirect URI must match what's configured in Google Cloud Console
REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback

# --- Frontend Configuration ---
# The URL where your frontend is hosted (e.g., Vercel URL)
FRONTEND_URL=https://your-frontend-domain.vercel.app
VITE_API_URL=https://your-backend-domain.com
